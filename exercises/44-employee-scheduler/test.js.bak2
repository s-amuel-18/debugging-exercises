/**
 * Pruebas para Employee Scheduler
 * Ejecutar con: npm test exercises/44-employee-scheduler
 */

const { Employee, Shift, Scheduler } = require('./solution.js');

describe('Employee Scheduler', () => {
  let scheduler;

  beforeEach(() => {
    scheduler = new Scheduler();
  });

  describe('Shift - creación y duración', () => {
    test('debe calcular las horas de un turno correctamente', () => {
      const shift = new Shift('morning', 8, 16); // 8h
      expect(shift.getDuration()).toBe(8);
    });

    test('debe detectar solapamiento entre dos turnos', () => {
      const s1 = new Shift('morning', 8, 16);
      const s2 = new Shift('overlap', 14, 20);
      expect(s1.overlaps(s2)).toBe(true);
    });

    test('NO debe detectar solapamiento en turnos consecutivos', () => {
      const s1 = new Shift('morning', 8, 16);
      const s2 = new Shift('afternoon', 16, 24);
      expect(s1.overlaps(s2)).toBe(false);
    });

    test('NO debe detectar solapamiento en turnos separados', () => {
      const s1 = new Shift('morning', 8, 12);
      const s2 = new Shift('evening', 14, 20);
      expect(s1.overlaps(s2)).toBe(false);
    });
  });

  describe('Scheduler - asignación de turnos', () => {
    test('debe asignar un turno a un empleado disponible', () => {
      const emp = new Employee('E001', 'Ana', ['lunes', 'martes'], 40);
      const shift = new Shift('morning', 8, 16);
      scheduler.assignShift(emp, shift, 'lunes');
      expect(emp.assignments.length).toBe(1);
    });

    test('debe rechazar turno si el empleado no está disponible ese día', () => {
      const emp = new Employee('E002', 'Luis', ['lunes'], 40);
      const shift = new Shift('morning', 8, 16);
      expect(() => scheduler.assignShift(emp, shift, 'martes')).toThrow();
    });

    test('debe rechazar turno si se supera el máximo de horas semanales', () => {
      const emp = new Employee('E003', 'Eva', ['lunes', 'martes', 'miercoles'], 20);
      const shift = new Shift('long', 8, 20); // 12h
      scheduler.assignShift(emp, shift, 'lunes'); // 12h ≤ 20h → ok
      expect(() => scheduler.assignShift(emp, shift, 'martes')).toThrow(); // 24h > 20h → throw
    });

    test('debe rechazar turno si hay solapamiento con uno ya asignado el mismo día', () => {
      const emp = new Employee('E004', 'Tom', ['lunes'], 40);
      const s1 = new Shift('morning', 8, 16);
      const s2 = new Shift('overlap', 14, 20);
      scheduler.assignShift(emp, s1, 'lunes');
      expect(() => scheduler.assignShift(emp, s2, 'lunes')).toThrow();
    });

    test('debe permitir turnos consecutivos (sin solapamiento) el mismo día', () => {
      const emp = new Employee('E005', 'Mia', ['lunes'], 40);
      const s1 = new Shift('morning', 8, 12);
      const s2 = new Shift('afternoon', 12, 16);
      scheduler.assignShift(emp, s1, 'lunes');
      expect(() => scheduler.assignShift(emp, s2, 'lunes')).not.toThrow();
      expect(emp.assignments.length).toBe(2);
    });
  });

  describe('Scheduler - reportes', () => {
    test('debe calcular el total de horas asignadas a un empleado', () => {
      const emp = new Employee('E006', 'Sam', ['lunes', 'martes', 'miercoles'], 40);
      scheduler.assignShift(emp, new Shift('s1', 8, 16), 'lunes');    // 8h
      scheduler.assignShift(emp, new Shift('s2', 9, 17), 'martes');   // 8h
      scheduler.assignShift(emp, new Shift('s3', 10, 14), 'miercoles'); // 4h
      expect(scheduler.getTotalHours(emp)).toBe(20);
    });

    test('debe retornar empleados con horas por debajo del mínimo', () => {
      const emp1 = new Employee('E007', 'Leo', ['lunes', 'martes'], 40);
      const emp2 = new Employee('E008', 'Zoe', ['lunes', 'martes'], 40);
      scheduler.assignShift(emp1, new Shift('s1', 8, 16), 'lunes'); // 8h
      scheduler.assignShift(emp2, new Shift('s2', 8, 16), 'lunes'); // 8h
      scheduler.assignShift(emp2, new Shift('s3', 8, 16), 'martes'); // 8h → 16h total
      const under = scheduler.getUnderscheduled([emp1, emp2], 10);
      expect(under.map(e => e.id)).toContain('E007');
      expect(under.map(e => e.id)).not.toContain('E008');
    });
  });
});
